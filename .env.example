# Public site URL — required for WhatsApp / social link previews (absolute og:image URLs).
VITE_SITE_URL=https://nacurva.pt

# Supabase — optional locally; required in production once the database is set up.
# Without these, the site falls back to the built-in static dress catalog.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cal.com — showroom visit embed on product pages (Portuguese site)
VITE_CAL_COM_BOOKING_URL=https://cal.com/your-username/your-event-pt
# English site — separate Cal event (optional; defaults to na-curva351/book-fiting)
VITE_CAL_COM_BOOKING_URL_EN=https://cal.com/your-username/your-event-en

# Admin panel (/admin) — server-only, never commit real values
ADMIN_PASSWORD=choose-a-strong-password
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
